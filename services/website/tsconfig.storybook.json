{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "emitDecoratorMetadata": true,
    "experimentalDecorators": true,
    "noEmit": false
  },
  "exclude": ["app/**/*.spec.ts", "app/**/*.test.ts"],
  "include": [
    "app/**/*.stories.ts",
    "app/**/*.stories.js",
    "app/**/*.stories.jsx",
    "app/**/*.stories.tsx",
    "app/**/*.stories.mdx",
    ".storybook/*.js",
    ".storybook/*.ts",
    ".storybook/main.tsx"
  ]
}
